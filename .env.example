PORT=4100
SERVER_HOST=0.0.0.0
SERVER_PORT=4100
PUBLIC_BASE_URL=http://localhost:4100
FRONTEND_ORIGIN=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

AUTH_ISSUER=http://localhost:9000
SSO_INTERNAL_BASE_URL=http://localhost:9000
SSO_INTERNAL_BASE_URLS=http://localhost:9000,http://host.docker.internal:9000
SSO_CLIENT_ID=cms-dashboard
SSO_CLIENT_SECRET=cms-dashboard-secret
SSO_ALLOWED_CLIENT_IDS=cms-dashboard
SSO_SERVICE_AUTH_SECRET=dev-sso-service-auth-secret
SSO_INTERNAL_AUTH_PATH=/api/internal/login
SSO_SCOPE=openid email profile roles offline_access
SSO_HTTP_TIMEOUT_MS=6000

AUTH_SESSION_SECRET=dev-cms-auth-session-secret-minimum-32-char
AUTH_JWT_SECRET=dev-cms-auth-jwt-secret-minimum-32-characters
AUTH_JWT_AUDIENCE=sijala-cms-api
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
AUTH_REFRESH_COOKIE_NAME=cms_refresh_token
AUTH_REFRESH_COOKIE_PATH=/api/auth
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
SPOT_FEED_FORMAT=auto
SPOT_FEED_POLL_INTERVAL_MS=180000
SPOT_FEED_TIMEOUT_MS=15000
TRACKER_ONLINE_WINDOW_MINUTES=10

# Production example behind Netlify/custom domain:
# PUBLIC_BASE_URL=https://cms.example.com
# FRONTEND_ORIGIN=https://cms.example.com
# CORS_ALLOWED_ORIGINS=https://cms.example.com
# AUTH_ISSUER=https://cms.example.com/sso
# SSO_INTERNAL_BASE_URL=http://202.74.75.177:9000
# SSO_INTERNAL_BASE_URLS=http://202.74.75.177:9000
# COOKIE_SECURE=true
